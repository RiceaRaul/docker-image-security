// Jenkins declarative pipeline — Docker image security
// Parameter IMAGE_VARIANT picks docker/Dockerfile (good) or docker/Dockerfile.bad (bad).
// Pipeline fails when the scanner finds HIGH/CRITICAL CVEs (expected for the bad variant).
// Author: Ricea Ion Raul (CSML, Software Security)

pipeline {
  agent {
    kubernetes {
      yamlFile 'ci/agent-pod.yaml'
      defaultContainer 'jnlp'
    }
  }

  parameters {
    choice(
      name: 'IMAGE_VARIANT',
      choices: ['good', 'bad'],
      description: 'Which Dockerfile to build/scan: "good" = hardened image; "bad" = intentionally vulnerable.'
    )
    string(
      name: 'FAIL_SEVERITY',
      defaultValue: 'HIGH,CRITICAL',
      description: 'Trivy severities that fail the build.'
    )
  }

  environment {
    REGISTRY      = 'registry.sec-lab.local'
    IMAGE         = "${REGISTRY}/secapp"
    TAG           = "${env.GIT_COMMIT?.take(8) ?: 'dev'}-${params.IMAGE_VARIANT}"
    REF           = "${IMAGE}:${TAG}"
    BUILDKIT_ADDR = 'unix:///run/buildkit/buildkitd.sock'
    DOCKERFILE    = "${params.IMAGE_VARIANT == 'bad' ? 'Dockerfile.bad' : 'Dockerfile'}"
  }

  options {
    timestamps()
    ansiColor('xterm')
    timeout(time: 30, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  stages {
    stage('Init') {
      steps {
        echo "===================================================================="
        echo " IMAGE_VARIANT = ${params.IMAGE_VARIANT}"
        echo " DOCKERFILE    = docker/${env.DOCKERFILE}"
        echo " REF           = ${env.REF}"
        echo " FAIL_SEVERITY = ${params.FAIL_SEVERITY}"
        echo "===================================================================="
        sh 'mkdir -p reports'
      }
    }

    stage('Lint Dockerfile') {
      steps {
        container('hadolint') {
          sh '''
            set +e
            hadolint docker/${DOCKERFILE} -f sarif > reports/hadolint.sarif
            HL_RC=$?
            hadolint docker/${DOCKERFILE} -f json  > reports/hadolint.json
            hadolint docker/${DOCKERFILE} | tee reports/hadolint.txt
            echo "Hadolint exit code: $HL_RC"
            exit 0
          '''
        }
      }
    }

    stage('Build (BuildKit)') {
      steps {
        container('buildkit') {
          sh '''
            buildctl --addr ${BUILDKIT_ADDR} build \
              --frontend dockerfile.v0 \
              --local context=. \
              --local dockerfile=docker \
              --opt filename=${DOCKERFILE} \
              --output type=oci,name=${REF},dest=image.tar
            ls -lh image.tar
          '''
        }
      }
    }

    stage('SBOM') {
      steps {
        container('syft') {
          sh '''
            syft oci-archive:image.tar -o cyclonedx-json=reports/sbom.json
            syft oci-archive:image.tar -o spdx-json=reports/sbom.spdx.json
            syft oci-archive:image.tar -o table | tee reports/sbom.txt
          '''
        }
      }
    }

    stage('Scan Image') {
      parallel {
        stage('Trivy CVE (gate)') {
          steps {
            container('trivy') {
              sh '''
                # Full table for the report
                trivy image --input image.tar --no-progress -f table | tee reports/trivy.txt

                # SARIF for Jenkins warnings-ng
                trivy image --input image.tar --no-progress \
                  --severity ${FAIL_SEVERITY} \
                  -f sarif -o reports/trivy.sarif

                # JSON for the summary step
                trivy image --input image.tar --no-progress \
                  --severity ${FAIL_SEVERITY} \
                  -f json -o reports/trivy.json

                # GATE: fail if any HIGH/CRITICAL found
                trivy image --input image.tar --no-progress \
                  --severity ${FAIL_SEVERITY} \
                  --exit-code 1 --ignore-unfixed=false \
                  -f table
              '''
            }
          }
        }
        stage('Grype CVE') {
          steps {
            container('grype') {
              sh '''
                grype oci-archive:image.tar -o sarif > reports/grype.sarif
                grype oci-archive:image.tar -o table | tee reports/grype.txt
              '''
            }
          }
        }
        stage('Trivy Misconfig') {
          steps {
            container('trivy') {
              sh 'trivy config docker/ -f sarif -o reports/trivy-config.sarif'
            }
          }
        }
        stage('Secret Scan') {
          steps {
            container('trivy') {
              sh 'trivy fs --scanners secret . -f sarif -o reports/trivy-secret.sarif'
            }
          }
        }
      }
    }

    stage('Policy Gate (Conftest on SBOM)') {
      steps {
        container('conftest') {
          sh 'conftest test reports/sbom.json --policy policy/conftest/ --output stdout || true'
        }
      }
    }

    stage('Sign + Attest (Cosign, offline)') {
      steps {
        container('cosign') {
          withCredentials([
            file(credentialsId: 'cosign-key', variable: 'COSIGN_KEY'),
            string(credentialsId: 'cosign-password', variable: 'COSIGN_PASSWORD'),
          ]) {
            sh '''
              cosign sign-blob   --key $COSIGN_KEY --yes --tlog-upload=false image.tar > reports/image.tar.sig
              cosign attest-blob --key $COSIGN_KEY --yes --tlog-upload=false \
                --predicate reports/sbom.json --type cyclonedx image.tar > reports/image.tar.intoto
            '''
          }
        }
      }
    }

    stage('Verify Signature') {
      steps {
        container('cosign') {
          sh '''
            cosign verify-blob --key cosign.pub \
              --signature reports/image.tar.sig \
              --insecure-ignore-tlog image.tar
          '''
        }
      }
    }
  }

  post {
    always {
      // Build a human summary of the run on the build node.
      container('trivy') {
        sh '''
          set +e
          {
            echo "===================================================================="
            echo " PIPELINE SUMMARY"
            echo "===================================================================="
            echo " Job        : ${JOB_NAME} #${BUILD_NUMBER}"
            echo " Commit     : ${GIT_COMMIT}"
            echo " Variant    : ${IMAGE_VARIANT}"
            echo " Dockerfile : docker/${DOCKERFILE}"
            echo " Image ref  : ${REF}"
            echo " Gate sev   : ${FAIL_SEVERITY}"
            echo
            if [ -f reports/trivy.json ]; then
              CRIT=$(grep -o '"Severity": *"CRITICAL"' reports/trivy.json | wc -l)
              HIGH=$(grep -o '"Severity": *"HIGH"'     reports/trivy.json | wc -l)
              MED=$(grep -o  '"Severity": *"MEDIUM"'   reports/trivy.json | wc -l)
              LOW=$(grep -o  '"Severity": *"LOW"'      reports/trivy.json | wc -l)
              echo " Trivy CVE counts:"
              echo "   CRITICAL : $CRIT"
              echo "   HIGH     : $HIGH"
              echo "   MEDIUM   : $MED"
              echo "   LOW      : $LOW"
              echo
              if [ "$CRIT" -gt 0 ] || [ "$HIGH" -gt 0 ]; then
                echo " GATE RESULT: FAIL  (HIGH/CRITICAL CVEs detected by Trivy)"
                echo
                echo " Top 10 offenders:"
                grep -E '"(PkgName|VulnerabilityID|Severity)"' reports/trivy.json \
                  | paste - - - | head -10
              else
                echo " GATE RESULT: PASS  (no HIGH/CRITICAL CVEs)"
              fi
            else
              echo " No Trivy report produced — scan stage did not run."
            fi
            echo
            echo " Artifacts archived:"
            ls -1 reports/ 2>/dev/null || true
            echo "===================================================================="
          } | tee reports/summary.txt
        '''
      }
      archiveArtifacts artifacts: 'reports/**', allowEmptyArchive: true
      recordIssues enabledForFailure: true, tools: [sarif(pattern: 'reports/*.sarif')]
    }
    success { echo " Build PASSED — image variant '${params.IMAGE_VARIANT}' cleared all gates." }
    failure { echo " Build FAILED — see PIPELINE SUMMARY above for the cause." }
  }
}
